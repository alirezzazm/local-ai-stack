{
  "name": "daz-desktop",
  "version": "1.0.0",
  "description": "DAZ desktop app — a window that connects to your DAZ server",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.daz.desktop",
    "productName": "DAZ",
    "win": { "target": "nsis" },
    "mac": { "target": "dmg" },
    "linux": { "target": "AppImage" }
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.0.0"
  }
}
